# Copy this file to `.env` and fill in real values.

# ---- Supabase ----
# Project URL, e.g. https://abcdefghijkl.supabase.co
# Find it under: Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# "anon" public key — safe to expose if you ever ship it to the browser.
# Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=your-anon-public-key

# "service_role" secret key — **server-only**, bypasses RLS. NEVER ship to browser.
# Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Direct Postgres connection string, used ONLY by `npm run migrate` to apply
# supabase/schema.sql. Get it from:
#   Dashboard → Project Settings → Database → Connection string → URI
#   (pick "Transaction pooler" or "Session pooler" — works from any network)
# The app itself doesn't need this at runtime; leave it blank in production.
SUPABASE_DB_URL=postgresql://postgres.YOUR-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ---- App ----
# Internal email domain used to map usernames → Supabase Auth emails.
# Users never see this; it just has to be a syntactically-valid domain.
AUTH_EMAIL_DOMAIN=flappy.local
