# Copy this file to `.env` and fill in real values.

# ---- Supabase ----
# Project URL, e.g. https://abcdefghijkl.supabase.co
# Find it under: Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# "anon" public key — safe to expose if you ever ship it to the browser.
# Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=your-anon-public-key

# "service_role" secret key — **server-only**, bypasses RLS. NEVER ship to browser.
# Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Postgres connection string, used ONLY by `npm run migrate` to apply
# supabase/schema.sql. Optional — you can also just paste schema.sql
# into the Supabase SQL editor. Get it from:
#   Dashboard → Project Settings → Database → Connection pooling
#     → "Session pooler"  (port 5432)  — recommended
#     OR "Transaction pooler" (port 6543)
# DO NOT use the "direct" db.<ref>.supabase.co host — it's IPv6-only on
# the free tier and times out from most networks. The pooler host is
# aws-0-<region>.pooler.supabase.com and works over IPv4.
# The app itself doesn't need this at runtime; leave blank in production.
SUPABASE_DB_URL=postgresql://postgres.YOUR-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ---- App ----
# Internal email domain used to map usernames → Supabase Auth emails.
# Users never see this; it just has to be a syntactically-valid domain.
AUTH_EMAIL_DOMAIN=flappy.local
